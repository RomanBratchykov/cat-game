# Supabase project URL (Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key (Dashboard -> Project Settings -> API)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional room name if you later support multiple rooms
VITE_DEFAULT_ROOM=main

# Optional confirmation redirect URL (must be allowed in Supabase Auth Redirect URLs)
VITE_AUTH_REDIRECT_TO=http://localhost:5173
